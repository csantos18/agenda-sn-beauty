{
  "version": 2,
  "functions": {
    "api/server.js": {
      "includeFiles": "{index.html,admin.html,termos.html,styles.css,script.js,admin.js,database.json}"
    }
  },
  "redirects": [
    {
      "source": "/",
      "destination": "/index.html",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/server.js"
    }
  ]
}
